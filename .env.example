# ============================================================
# VARIABLES DE ENTORNO — Copia este archivo como .env.local
# ============================================================

# === GOOGLE SHEETS (Base de datos — DOS sheets) ===
GOOGLE_SHEETS_PUBLIC_ID=            # Sheet pública (productos, reseñas, blog, config)
GOOGLE_SHEETS_PRIVATE_ID=           # Sheet privada (usuarios, pedidos, perfiles)
GOOGLE_SHEETS_CLIENT_EMAIL=         # Email de la service account
GOOGLE_SHEETS_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\ntu_key_aqui\n-----END PRIVATE KEY-----\n"

# === NEXTAUTH (Autenticación) ===
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=                    # Generá con: openssl rand -base64 32

# === GOOGLE OAUTH (Login con Google) ===
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# === ADMIN (Roles) ===
ADMIN_EMAILS=admin@ejemplo.com      # Emails admin separados por coma (case-insensitive)

# === SEED (Endpoints destructivos /api/seed y /api/resenas/seed) ===
SEED_SECRET=                        # Token para endpoints de seed (generar con: openssl rand -hex 32)

# === URL PÚBLICA (usada en sitemap, OG images, canonical URLs) ===
NEXT_PUBLIC_BASE_URL=https://tudominio.com

# === MERCADOPAGO (Pagos) ===
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_PUBLIC_KEY=
MERCADOPAGO_WEBHOOK_SECRET=         # Para verificar firma de webhooks

# === OPENAI (Kira — Asistente IA) ===
OPENAI_API_KEY=

# === DESCUENTOS Y TRANSFERENCIA BANCARIA ===
NEXT_PUBLIC_TRANSFER_DISCOUNT=10    # Porcentaje de descuento por transferencia (default: 10)
NEXT_PUBLIC_TRANSFER_CBU=           # CBU visible en la pantalla de transferencia
NEXT_PUBLIC_TRANSFER_ALIAS=         # Alias visible en la pantalla de transferencia
NEXT_PUBLIC_TRANSFER_TITULAR=       # Nombre del titular de la cuenta

# === WHATSAPP (contacto directo desde el chat y botones CTA) ===
NEXT_PUBLIC_EVOLUTION_PHONE=        # Telefono con codigo de pais, sin + (ej: 5491123456789)

# === GOOGLE MAPS (tracking con mapa en /tracking/[orderId]) ===
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# === PUSH NOTIFICATIONS (Web Push VAPID — opcional) ===
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
NEXT_PUBLIC_VAPID_PUBLIC_KEY=       # igual que VAPID_PUBLIC_KEY, accesible desde el cliente

# === n8n (Flujos de automatización) ===
N8N_API_URL=                        # URL de tu instancia n8n
N8N_API_KEY=                        # API key de n8n

# === CLOUDFLARE R2 (Almacenamiento de imágenes — opcional) ===
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=                     # ej: ecomflex
R2_PUBLIC_URL=                      # ej: https://pub-xxx.r2.dev


# ═══════════════════════════════════════════════════════════════
# Variables usadas SOLO por n8n (no por Next.js)
# Setearlas en el panel de n8n, no en Vercel.
# Estan aca como referencia para no perderlas.
# ═══════════════════════════════════════════════════════════════

# === EMAIL MARKETING (Gmail vía n8n) ===
GMAIL_SENDER_EMAIL=
GMAIL_SENDER_NAME=

# === REDES SOCIALES (publicacion automatizada vía n8n) ===
BLOTATO_API_KEY=                    # Instagram (publicación vía Blotato)
TWITTER_API_KEY=
TWITTER_API_SECRET=
TIKTOK_API_KEY=

# === GOOGLE ADS (tracking server-side vía n8n) ===
GOOGLE_ADS_TRACKING_ID=

# === WHATSAPP (Evolution API vía n8n) ===
WHATSAPP_NUMBER=

# === CRYPTO (USDT — mostrar datos de wallet en checkout) ===
CRYPTO_WALLET_ADDRESS=
CRYPTO_NETWORK=                     # ej: TRC20, BEP20

# === ANALYTICS ===
VERCEL_ANALYTICS_ID=
