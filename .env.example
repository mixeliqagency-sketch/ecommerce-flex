# ============================================================
# VARIABLES DE ENTORNO — Copia este archivo como .env.local
# ============================================================

# === GOOGLE SHEETS (Base de datos — DOS sheets) ===
GOOGLE_SHEETS_PUBLIC_ID=            # Sheet pública (productos, reseñas, blog, config)
GOOGLE_SHEETS_PRIVATE_ID=           # Sheet privada (usuarios, pedidos, perfiles)
GOOGLE_SHEETS_CLIENT_EMAIL=         # Email de la service account
GOOGLE_SHEETS_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\ntu_key_aqui\n-----END PRIVATE KEY-----\n"

# === NEXTAUTH (Autenticación) ===
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=                    # Generá con: openssl rand -base64 32

# === GOOGLE OAUTH (Login con Google) ===
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# === ADMIN (Roles) ===
ADMIN_EMAILS=admin@ejemplo.com      # Emails admin separados por coma

# === MERCADOPAGO (Pagos) ===
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_PUBLIC_KEY=
MERCADOPAGO_WEBHOOK_SECRET=         # Para verificar firma de webhooks

# === OPENAI (Kira — Asistente IA) ===
OPENAI_API_KEY=

# === DESCUENTOS ===
NEXT_PUBLIC_TRANSFER_DISCOUNT=10    # Porcentaje de descuento por transferencia (default: 10)

# === n8n (Flujos de automatización) ===
N8N_API_URL=                        # URL de tu instancia n8n
N8N_API_KEY=                        # API key de n8n

# === EMAIL MARKETING (Gmail vía n8n) ===
GMAIL_SENDER_EMAIL=
GMAIL_SENDER_NAME=

# === REDES SOCIALES (opcional) ===
BLOTATO_API_KEY=                    # Instagram (publicación vía Blotato)
TWITTER_API_KEY=
TWITTER_API_SECRET=
TIKTOK_API_KEY=

# === GOOGLE ADS (opcional) ===
GOOGLE_ADS_TRACKING_ID=

# === PUSH NOTIFICATIONS (Web Push VAPID — opcional) ===
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# === WHATSAPP (Evolution API vía n8n — opcional) ===
WHATSAPP_NUMBER=

# === CLOUDFLARE R2 (Almacenamiento de imágenes — opcional) ===
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=                     # ej: ecomflex
R2_PUBLIC_URL=                      # ej: https://pub-xxx.r2.dev

# === CRYPTO (USDT — opcional) ===
CRYPTO_WALLET_ADDRESS=
CRYPTO_NETWORK=                     # ej: TRC20, BEP20

# === ANALYTICS (opcional) ===
VERCEL_ANALYTICS_ID=
