# ============================================================
# VARIABLES DE ENTORNO — Copia este archivo como .env.local
# ============================================================

# === GOOGLE SHEETS (Base de datos de productos) ===
GOOGLE_SHEETS_SPREADSHEET_ID=tu_spreadsheet_id
GOOGLE_SHEETS_CLIENT_EMAIL=tu_service_account@proyecto.iam.gserviceaccount.com
GOOGLE_SHEETS_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\ntu_private_key\n-----END PRIVATE KEY-----\n"

# === NEXTAUTH (Autenticacion) ===
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=genera_un_secreto_con_openssl_rand_base64_32

# === GOOGLE OAUTH (Login con Google) ===
GOOGLE_CLIENT_ID=tu_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=tu_google_client_secret

# === MERCADOPAGO (Pagos) ===
MERCADOPAGO_ACCESS_TOKEN=tu_access_token
MERCADOPAGO_PUBLIC_KEY=tu_public_key

# === OPENAI (Asistente virtual con IA) ===
OPENAI_API_KEY=sk-tu_api_key
